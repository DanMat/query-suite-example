{
  "name": "query-suite-example",
  "version": "1.0.0",
  "private": true,
  "description": "A runnable example wiring together the @danmat HTTP QUERY (RFC 10008) suite: a stock-screener API and client using query-fetch, accept-query, query-cache, and query-server.",
  "type": "module",
  "scripts": {
    "demo": "tsx src/demo.ts",
    "start": "tsx src/start.ts",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "prepare": "husky"
  },
  "author": "Dan Matthew <dannymatthew@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@danmat/accept-query": "^0.1.0",
    "@danmat/query-cache": "^0.1.0",
    "@danmat/query-fetch": "^0.1.0",
    "@danmat/query-server": "^0.1.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^20.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.114.17"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc,md}": "biome check --write --no-errors-on-unmatched"
  }
}
